# Local database path (used by scripts: seed, migrate, etc.)
DATABASE_URL=local.db

# Session secret — used to sign session cookies (generate a random string)
SESSION_SECRET=change-me

# Cloudflare D1 credentials — required for drizzle-kit operations against remote D1
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_DATABASE_ID=
# CLOUDFLARE_D1_TOKEN=
