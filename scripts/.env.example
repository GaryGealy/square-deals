# -----------------------------------------------------------------------------
# Local development environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# -----------------------------------------------------------------------------

# Path to the local SQLite database file (created automatically on first migration)
DATABASE_URL=local.db

# Secret used to sign session cookies — must be a long random string
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-me

# -----------------------------------------------------------------------------
# Cloudflare D1 — only needed for remote database operations
# (running migrations or drizzle-kit commands against production)
# These are NOT needed for local development
# -----------------------------------------------------------------------------
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_DATABASE_ID=
# CLOUDFLARE_D1_TOKEN=
